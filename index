      {time:"10.00–11.00", title:"ศึกษาดูงาน", place:"โรงเรียนวัดดอนไก่เตี้ย", icon:"🏫", lat:13.124188, lng:99.9373395, images:[IMG_SCHOOL1, IMG_SCHOOL2]},
      {time:"12.00–13.30", title:"รับประทานอาหารเที่ยง", place:"The Pomelo Amphawa (ครัวส้มโอหวาน อัมพวา)", icon:"🍋", lat:13.4075474, lng:99.9597567, images:[IMG_POMELO1, IMG_POMELO2]},
      {time:"13.45–14.45", title:"เยี่ยมชม", place:"วัดจุฬามณี จ.สมุทรสงคราม", icon:"🛕", lat:13.42657, lng:99.9653489, images:[IMG_WAT1, IMG_WAT2]},
      {time:"15.15–15.45", title:"แวะซื้อของฝาก", place:"ระหว่างทางกลับพัทยา", icon:"🛍️", lat:13.4472804, lng:100.0752432},
      {time:"19.30", title:"กลับถึงพัทยา", place:"จุดหมายปลายทาง พัทยา", icon:"🌙", lat:12.923594, lng:100.8824376}
