let activeDay = 0;
let currentStopIndex = 0;
let moveMode = 'fly'; // 'fly' = ซูมเข้านุ่มนวล, 'pulse' = ไฟกระพริบ ไม่ซูม
let map, routeLine, markers = [];
let currentRouteLatLngs = null;
let stopRouteIdx = [];
let travelMarker = null;

function parseStopDurationMinutes(timeStr){
  const parts = timeStr.split('–').map(p => p.trim());
  if(parts.length !== 2) return null;
  const [h1, m1] = parts[0].split('.').map(Number);
  const [h2, m2] = parts[1].split('.').map(Number);
  if([h1,m1,h2,m2].some(n => Number.isNaN(n))) return null;
  let diff = (h2*60+m2) - (h1*60+m1);
  if(diff < 0) diff += 24*60;
  return diff;
}
function formatStopDuration(mins){
  if(mins == null) return '';
  if(mins < 60) return `${mins} นาที`;
  const h = Math.floor(mins/60), m = mins % 60;
  return m ? `${h} ชม. ${m} นาที` : `${h} ชม.`;
}

function initMap(){
  map = L.map('map', {scrollWheelZoom:false}).setView([13.0,100.2], 8);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 18,
    attribution: '&copy; OpenStreetMap contributors'
  }).addTo(map);

  const mapEl = document.getElementById('map');
  mapEl.addEventListener('mouseenter', ()=> map.scrollWheelZoom.enable());
  mapEl.addEventListener('mouseleave', ()=> map.scrollWheelZoom.disable());

  renderDay(0);
}

function renderDay(dayIdx){
  activeDay = dayIdx;

  document.querySelectorAll('.day-tab').forEach((el,i)=>{
    el.classList.toggle('active', i===dayIdx);
  });

  const stops = DAYS[dayIdx].stops;

  document.getElementById('timelineTitle').textContent = `กำหนดการ · ${DAYS[dayIdx].label}`;
  document.getElementById('timelineCount').textContent = `${stops.length} รายการ`;

  const tl = document.getElementById('timelineList');
  tl.innerHTML = '';
  stops.forEach((s, i)=>{
    const dur = parseStopDurationMinutes(s.time);
    const div = document.createElement('div');
    div.className = 'stop' + (i===0 ? ' active' : '');
    div.dataset.idx = i;
    div.tabIndex = 0;
    div.innerHTML = `
      <div class="marker-num">${i+1}</div>
      <div class="icon">${s.icon}</div>
      <div class="body">
        <div class="time">${s.time}${dur ? `<span class="duration-badge">${formatStopDuration(dur)}</span>` : ''}</div>
        <div class="title">${s.title}</div>
        <div class="place-note">${s.place}</div>
        ${s.tbd ? '<span class="tbd">แตะแก้ไขหัวข้อภายหลัง</span>' : ''}
        ${s.images ? `<div class="thumbs">${s.images.map(src=>`<img src="${src}" alt="${s.title}">`).join('')}</div>` : ''}
      </div>
    `;
    if(s.images){
      div.querySelectorAll('.thumbs img').forEach(imgEl=>{
        imgEl.addEventListener('click', (e)=>{ e.stopPropagation(); openModal(i); });
      });
    }
    div.addEventListener('click', ()=> focusStop(i, true));
    div.addEventListener('keydown', (e)=>{ if(e.key==='Enter' || e.key===' '){ e.preventDefault(); focusStop(i, true); }});
    tl.appendChild(div);

    if(i < stops.length - 1){
      const leg = document.createElement('div');
      leg.className = 'leg-connector';
      leg.dataset.leg = i;
      leg.innerHTML = `<span class="leg-icon">🚗</span><span class="leg-text pending">กำลังคำนวณเส้นทาง…</span>`;
      tl.appendChild(leg);
    }
  });

  markers.forEach(m=>map.removeLayer(m));
  markers = [];
  if(routeLine) map.removeLayer(routeLine);

  const latlngs = stops.map(s=>[s.lat,s.lng]);
  routeLine = L.polyline(latlngs, {color:'#E8703A', weight:3, dashArray:'6,8', opacity:0.85}).addTo(map);

  stops.forEach((s,i)=>{
    const icon = L.divIcon({
      className:'',
      html:`<div style="
        background:${i===0?'#E8703A':'#0B4F6C'};
        color:#fff;width:28px;height:28px;border-radius:50%;
        display:flex;align-items:center;justify-content:center;
        font-family:'Space Mono',monospace;font-size:.75rem;font-weight:700;
        box-shadow:0 4px 10px rgba(0,0,0,0.35);border:2px solid #fff;">${i+1}</div>`,
      iconSize:[28,28],
      iconAnchor:[14,14]
    });
    const marker = L.marker([s.lat,s.lng], {icon}).addTo(map);
    marker.bindPopup(`<b>${s.time}</b><br>${s.title}<br><span style="color:#5a5f5a">${s.place}</span>`);
    marker.on('click', ()=> focusStop(i, false));
    markers.push(marker);
  });

  map.fitBounds(routeLine.getBounds(), {padding:[36,36]});
  document.getElementById('mapCaption').textContent = `เส้นทาง ${DAYS[dayIdx].label} · ${stops.length} จุดแวะ · กำลังโหลดเส้นถนนจริง…`;

  currentStopIndex = 0;
  currentRouteLatLngs = null;
  stopRouteIdx = [];
  if(travelMarker){ map.removeLayer(travelMarker); travelMarker = null; }
  updatePreview(0);

  loadRoadRoute(stops, dayIdx, ++currentRequestId);
}

function updatePreview(i){
  const stops = DAYS[activeDay].stops;
  const s = stops[i];
  document.getElementById('cpIcon').textContent = s.icon;
  document.getElementById('cpTime').textContent = s.time;
  document.getElementById('cpTitle').textContent = s.title;
  document.getElementById('cpCounter').textContent = `${i+1}/${stops.length}`;
  document.getElementById('prevBtn').disabled = (i === 0);
  document.getElementById('nextBtn').disabled = (i === stops.length - 1);
}

let currentRequestId = 0;

function haversineKm(lat1, lon1, lat2, lon2){
  const R = 6371;
  const dLat = (lat2 - lat1) * Math.PI / 180;
  const dLon = (lon2 - lon1) * Math.PI / 180;
  const a = Math.sin(dLat/2)**2 + Math.cos(lat1*Math.PI/180) * Math.cos(lat2*Math.PI/180) * Math.sin(dLon/2)**2;
  return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
}
function formatDistance(m){ return (m/1000).toFixed(1) + ' กม.'; }
function formatDuration(sec){
  const totalMin = Math.round(sec/60);
  if(totalMin < 60) return totalMin + ' นาที';
  return `${Math.floor(totalMin/60)} ชม. ${totalMin%60} นาที`;
}

function nearestRouteIndex(latlngs, lat, lng){
  let best = 0, bestDist = Infinity;
  for(let idx = 0; idx < latlngs.length; idx++){
    const dLat = latlngs[idx][0] - lat;
    const dLng = latlngs[idx][1] - lng;
    const d = dLat*dLat + dLng*dLng;
    if(d < bestDist){ bestDist = d; best = idx; }
  }
  return best;
}

function ensureTravelMarker(){
  if(travelMarker) return travelMarker;
  travelMarker = L.marker([0,0], {
    icon: L.divIcon({ className:'', html:'<div class="travel-dot">🚐</div>', iconSize:[26,26], iconAnchor:[13,13] }),
    interactive:false,
    opacity:0,
    zIndexOffset:1000
  });
  return travelMarker;
}

function animateAlongRoute(fromIdx, toIdx, duration){
  if(!currentRouteLatLngs || fromIdx == null || toIdx == null || fromIdx === toIdx) return;
  const path = fromIdx < toIdx
    ? currentRouteLatLngs.slice(fromIdx, toIdx + 1)
    : currentRouteLatLngs.slice(toIdx, fromIdx + 1).reverse();
  if(path.length < 2) return;

  const marker = ensureTravelMarker();
  if(!map.hasLayer(marker)) marker.addTo(map);
  marker.setLatLng(path[0]);
  marker.setOpacity(1);

  const start = performance.now();
  function step(now){
    const t = Math.min(1, (now - start) / duration);
    const segFloat = t * (path.length - 1);
    const segIdx = Math.floor(segFloat);
    const segT = segFloat - segIdx;
    const a = path[segIdx];
    const b = path[Math.min(segIdx + 1, path.length - 1)];
    marker.setLatLng([a[0] + (b[0]-a[0])*segT, a[1] + (b[1]-a[1])*segT]);
    if(t < 1){
      requestAnimationFrame(step);
    } else {
      setTimeout(()=> marker.setOpacity(0), 400);
    }
  }
  requestAnimationFrame(step);
}

async function loadRoadRoute(stops, dayIdx, requestId){
  const coordStr = stops.map(s => `${s.lng},${s.lat}`).join(';');
  const url = `https://router.project-osrm.org/route/v1/driving/${coordStr}?overview=full&geometries=geojson`;
  try{
    const res = await fetch(url);
    if(!res.ok) throw new Error('routing service error');
    const data = await res.json();
    if(requestId !== currentRequestId) return; // ผู้ใช้สลับวันไปแล้ว ผลลัพธ์นี้ไม่ทันสมัย
    if(data.code !== 'Ok' || !data.routes || !data.routes[0]) throw new Error('no route found');

    const route = data.routes[0];
    const latlngs = route.geometry.coordinates.map(c => [c[1], c[0]]);

    if(routeLine) map.removeLayer(routeLine);
    routeLine = L.polyline(latlngs, {color:'#0B4F6C', weight:4, opacity:0.85, lineJoin:'round'}).addTo(map);
    map.fitBounds(routeLine.getBounds(), {padding:[36,36]});

    currentRouteLatLngs = latlngs;
    stopRouteIdx = stops.map(s => nearestRouteIndex(latlngs, s.lat, s.lng));

    route.legs.forEach((leg, i)=>{
      const el = document.querySelector(`.leg-connector[data-leg="${i}"] .leg-text`);
      if(el){
        el.textContent = `${formatDistance(leg.distance)} · เวลาโดยประมาณ ${formatDuration(leg.duration)} (ถนนจริง)`;
        el.classList.remove('pending');
      }
    });

    document.getElementById('mapCaption').textContent =
      `เส้นทางถนนจริง ${DAYS[dayIdx].label} · รวม ${formatDistance(route.distance)} · เวลาโดยประมาณ ${formatDuration(route.duration)}`;
  } catch(err){
    if(requestId !== currentRequestId) return;
    stops.forEach((s,i)=>{
      if(i < stops.length - 1){
        const d = haversineKm(s.lat, s.lng, stops[i+1].lat, stops[i+1].lng);
        const el = document.querySelector(`.leg-connector[data-leg="${i}"] .leg-text`);
        if(el){
          el.textContent = `~${d.toFixed(1)} กม. (เส้นตรงโดยประมาณ)`;
          el.classList.remove('pending');
        }
      }
    });
    document.getElementById('mapCaption').textContent =
      `เส้นทาง ${DAYS[dayIdx].label} · โหลดเส้นถนนจริงไม่สำเร็จ แสดงระยะทางประมาณแทน`;
  }
}

function pulseMarker(i){
  const el = markers[i].getElement();
  if(!el) return;
  const inner = el.querySelector('div');
  if(!inner) return;
  inner.classList.remove('pin-pulse');
  void inner.offsetWidth; // reflow เพื่อรีสตาร์ท animation
  inner.classList.add('pin-pulse');
  setTimeout(()=> inner.classList.remove('pin-pulse'), 1500);
}

let popupCloseTimer = null;
function openPopupWithAutoClose(marker){
  if(popupCloseTimer) clearTimeout(popupCloseTimer);
  marker.openPopup();
  popupCloseTimer = setTimeout(()=> marker.closePopup(), 3000);
}

function focusStop(i, fromTimeline){
  const prevIdx = currentStopIndex;
  currentStopIndex = i;

  document.querySelectorAll('.stop').forEach((el)=>{
    el.classList.toggle('active', Number(el.dataset.idx)===i);
  });
  markers.forEach((m,mi)=>{
    const el = m.getElement();
    if(el){
      const inner = el.querySelector('div');
      if(inner) inner.style.background = (mi===i) ? '#E8703A' : '#0B4F6C';
    }
  });

  const s = DAYS[activeDay].stops[i];

  if(fromTimeline){
    if(moveMode === 'fly'){
      map.flyTo([s.lat,s.lng], 12, {duration:1.5});
      if(prevIdx !== i && stopRouteIdx.length){
        animateAlongRoute(stopRouteIdx[prevIdx], stopRouteIdx[i], 1500);
      }
    } else {
      pulseMarker(i);
    }
  }

  openPopupWithAutoClose(markers[i]);
  updatePreview(i);
  document.querySelectorAll('.stop')[i].scrollIntoView({behavior:'smooth', block:'nearest'});
}

const zoomSwitch = document.getElementById('zoomSwitch');
const zoomDesc = document.getElementById('zoomDesc');
function setZoomMode(on){
  moveMode = on ? 'fly' : 'pulse';
  zoomSwitch.classList.toggle('on', on);
  zoomSwitch.setAttribute('aria-checked', on ? 'true' : 'false');
  zoomDesc.textContent = on
    ? 'เปิด: ซูมเข้าดูจุดที่เลือกแบบนุ่มนวล (1.5 วิ)'
    : 'ปิด: หมุดกระพริบแทน ไม่ซูม เห็นภาพรวมทั้งเส้นทาง';
  if(!on && routeLine){
    map.fitBounds(routeLine.getBounds(), {padding:[36,36]});
  }
}
zoomSwitch.addEventListener('click', ()=> setZoomMode(!zoomSwitch.classList.contains('on')));

document.getElementById('prevBtn').addEventListener('click', ()=>{
  const next = Math.max(0, currentStopIndex - 1);
  focusStop(next, true);
});
document.getElementById('nextBtn').addEventListener('click', ()=>{
  const stops = DAYS[activeDay].stops;
  const next = Math.min(stops.length - 1, currentStopIndex + 1);
  focusStop(next, true);
});

document.querySelectorAll('.day-tab').forEach(btn=>{
  btn.addEventListener('click', ()=> renderDay(Number(btn.dataset.day)));
});

const modalOverlay = document.getElementById('stopModal');

function renderModal(i){
  const stops = DAYS[activeDay].stops;
  const s = stops[i];
  const gallery = document.getElementById('modalGallery');
  gallery.innerHTML = s.images
    ? s.images.map(src => `<img src="${src}" alt="${s.title}">`).join('')
    : '<div class="modal-noimg">ยังไม่มีรูปสำหรับสถานที่นี้</div>';

  const dur = parseStopDurationMinutes(s.time);
  document.getElementById('modalTime').textContent = dur ? `${s.time} · ใช้เวลา ${formatStopDuration(dur)}` : s.time;
  document.getElementById('modalTitle').textContent = s.title;
  document.getElementById('modalPlace').textContent = s.place;
  document.getElementById('modalNote').textContent = s.tbd ? 'หัวข้อยังไม่สรุป รอข้อมูลเพิ่มเติม' : '';
  document.getElementById('modalCounter').textContent = `${i+1}/${stops.length}`;
  document.getElementById('modalPrev').disabled = (i === 0);
  document.getElementById('modalNext').disabled = (i === stops.length - 1);
}

function openModal(i){
  currentStopIndex = i;
  renderModal(i);
  modalOverlay.classList.add('open');
  modalOverlay.setAttribute('aria-hidden', 'false');
}
function closeModal(){
  modalOverlay.classList.remove('open');
  modalOverlay.setAttribute('aria-hidden', 'true');
}

document.getElementById('modalClose').addEventListener('click', closeModal);
modalOverlay.addEventListener('click', (e)=>{ if(e.target === modalOverlay) closeModal(); });
document.addEventListener('keydown', (e)=>{ if(e.key === 'Escape') closeModal(); });

document.getElementById('modalPrev').addEventListener('click', ()=>{
  const next = Math.max(0, currentStopIndex - 1);
  currentStopIndex = next;
  renderModal(next);
  focusStop(next, false);
  updatePreview(next);
});
document.getElementById('modalNext').addEventListener('click', ()=>{
  const stops = DAYS[activeDay].stops;
  const next = Math.min(stops.length - 1, currentStopIndex + 1);
  currentStopIndex = next;
  renderModal(next);
  focusStop(next, false);
  updatePreview(next);
});

