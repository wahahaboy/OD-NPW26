async function fetchWeatherForDay(dayIdx, lat, lng, dateStr){
  const el = document.getElementById(`weather-${dayIdx}`);
  if(!el) return;
  try{
    const url = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lng}&daily=weathercode,temperature_2m_max,temperature_2m_min,precipitation_probability_max&timezone=Asia%2FBangkok&start_date=${dateStr}&end_date=${dateStr}`;
    const res = await fetch(url);
    if(!res.ok) throw new Error('weather fetch failed');
    const data = await res.json();
    if(!data.daily || !data.daily.time || !data.daily.time.length) throw new Error('no data for this date');

    const code = data.daily.weathercode[0];
    const tmax = Math.round(data.daily.temperature_2m_max[0]);
    const tmin = Math.round(data.daily.temperature_2m_min[0]);
    const rain = data.daily.precipitation_probability_max ? data.daily.precipitation_probability_max[0] : null;
    const info = weatherCodeInfo(code);
    el.textContent = `${info.icon} ${info.label} · ${tmin}–${tmax}°C${rain != null ? ` · โอกาสฝน ${rain}%` : ''}`;
  } catch(err){
    el.textContent = '🌡️ ไม่มีข้อมูลพยากรณ์สำหรับวันที่นี้';
  }
}

fetchWeatherForDay(0, 12.7748742, 99.9763563, '2026-07-13'); // ชะอำ/เพชรบุรี
fetchWeatherForDay(1, 13.4075474, 99.9597567, '2026-07-14'); // อัมพวา/สมุทรสงคราม

initMap();
